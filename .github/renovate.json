{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>SonarSource/renovate-config:quality-corelang-squad"
  ],
  "ignorePaths": [
    "its/projects/**"
  ],
  "nuget": {
    "description": "ignorePaths in the root does not work due to higher-precedence built-in counter-intuitive nuget-specifc defaults",
    "ignorePaths": [
      "its/projects/**"
    ]
  },
  "packageRules": [
    {
      "description": "Do not update Build dependency. It provides backward compatibility with MsBuild 14+",
      "matchPackageNames": [
        "Microsoft.Build**"
      ],
      "enabled": false
    },
    {
      "description": "Refresh NuGet lockfiles with .NET 10 after dependency updates",
      "matchManagers": [
        "nuget"
      ],
      "skipArtifactsUpdate": true,
      "constraints": {
        "dotnet": ">=10.0.100 <11.0.0"
      },
      "postUpgradeTasks": {
        "installTools": {
          "dotnet": {}
        },
        "commands": [
          "dotnet restore SonarScanner.MSBuild.sln --force-evaluate"
        ],
        "fileFilters": [
          "**/packages.lock.json"
        ]
      }
    }
  ]
}
