<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>dotnet-sonarscanner</id>
    <version>$Version$</version>
    <title>SonarScanner for .NET</title>
    <authors>SonarSource</authors>
    <projectUrl>https://redirect.sonarsource.com/doc/msbuild-sq-runner.html</projectUrl>
    <iconUrl>https://cdn.rawgit.com/SonarSource/sonar-scanner-msbuild/cdd1f588/icon.png</iconUrl>
    <license type="file">licenses/LICENSE.txt</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <summary>The SonarScanner for .NET allows easy analysis of any .NET project with SonarQube Server and Cloud.</summary>
    <description>The SonarScanner for .NET allows easy analysis of any .NET project with SonarQube Server and Cloud.</description>
    <readme>docs\README.md</readme>
    <tags>sonarqube sonarcloud msbuild scanner sonarsource sonar sonar-scanner sonarscanner</tags>
    <copyright>SonarSource Sàrl</copyright>
    <releaseNotes>All release notes for SonarScanner .NET can be found on the GitHub site - https://github.com/SonarSource/sonar-scanner-msbuild/releases</releaseNotes>
    <packageTypes>
      <packageType name="DotnetTool" />
    </packageTypes>
    <dependencies>
      <group targetFramework=".NETCoreApp3.1" />
    </dependencies>
  </metadata>
  <files>
    <file src="..\Binaries\Net\*.*" target="tools\netcoreapp3.1\any\" />
    <file src="..\Binaries\Net\Targets\*" target="tools\netcoreapp3.1\any\Targets\" />
    <file src="..\Binaries\Net\Licenses\" target="licenses\" />
    <file src="DotnetToolSettings.xml" target="tools\netcoreapp3.1\any\DotnetToolSettings.xml" />
    <file src="..\..\README.md" target="docs\" />
  </files>
</package>
